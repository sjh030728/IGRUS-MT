{
  "name": "@mt/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/main.js",
    "dev": "tsc -w -p tsconfig.json",
    "verify": "node verify-loop.mjs",
    "verify:live": "node verify-live.mjs",
    "db:seed": "node db/seed.mjs",
    "db:seed:example": "node db/seed.mjs db/quiz.questions.example.json"
  },
  "dependencies": {
    "@mt/protocol": "*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/websockets": "^10.4.15",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.6.0"
  }
}
